# =========================================================================
# ApplyAI Environment Configuration Example
# Copy this file to .env.local and configure your credentials.
# =========================================================================

# -------------------------------------------------------------------------
# AI Provider & Model Customization
# -------------------------------------------------------------------------
# Choose the target inference provider:
# - "groq"   : Llama inference via Groq Console (default)
# - "google" : Gemini inference via Google AI Studio
AI_PROVIDER="groq"

# Custom Model Name:
# - For Groq (default): "llama-3.3-70b-versatile"
# - For Google: "gemini-3.1-flash-lite" or "gemini-3.5-flash"
AI_MODEL="llama-3.3-70b-versatile"

# -------------------------------------------------------------------------
# API Keys & Provider Credentials
# -------------------------------------------------------------------------
# Groq API Key: Obtain yours from https://console.groq.com
GROQ_API_KEY="your_groq_api_key_here"

# Google Gemini API Key: Obtain yours from https://aistudio.google.com/apikey
# Required if AI_PROVIDER is set to "google"
GOOGLE_GENERATIVE_AI_API_KEY="your_google_ai_api_key_here"

# -------------------------------------------------------------------------
# Application Security Configuration
# -------------------------------------------------------------------------
# Shared API key to secure internal/automated triggers for the comparison endpoint.
# Requests without a Clerk session must supply this key via the 'x-api-key' header.
API_KEY="your_application_api_key_here"

# Optional: Port to host local server on (defaults to 3000)
PORT=3000

# -------------------------------------------------------------------------
# Clerk Authentication Configuration
# -------------------------------------------------------------------------
# Retrieve these credentials from your Clerk Dashboard: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="your_clerk_publishable_key_here"
CLERK_SECRET_KEY="your_clerk_secret_key_here"

# Clerk Application Redirect Routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Clerk Frontend API URL:
# Find this under Clerk Dashboard -> Integrations -> Convex
# Used by Convex auth.config.ts to validate JWT issuer signatures
CLERK_FRONTEND_API_URL="https://your-clerk-instance.clerk.accounts.dev"

# -------------------------------------------------------------------------
# Convex Database Configuration
# -------------------------------------------------------------------------
# These values are printed in your terminal after starting: npx convex dev
NEXT_PUBLIC_CONVEX_URL="https://your-project.convex.cloud"
NEXT_PUBLIC_CONVEX_SITE_URL="https://your-project.convex.site"
