# Groq API Key (Obtain yours from https://console.groq.com)
GROQ_API_KEY="your_groq_api_key_here"

# Application API Key for securing the comparison endpoint
API_KEY="your_application_api_key_here"
NEXT_PUBLIC_API_KEY="your_application_api_key_here"

# Optional: Host Server Port (Defaults to 3000)
PORT=3000

# Clerk Authentication Configuration
# Find these keys in your Clerk Dashboard: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="your_clerk_publishable_key_here"
CLERK_SECRET_KEY="your_clerk_secret_key_here"

# Clerk redirect routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Clerk JWT Issuer Domain for Convex auth
# Find in Clerk Dashboard -> Configure -> JWT Templates
CLERK_JWT_ISSUER_DOMAIN="https://your-clerk-instance.clerk.accounts.dev"

# Convex URLs (run `npx convex dev` to get these)
# They will be printed in the terminal after deployment starts
NEXT_PUBLIC_CONVEX_URL="https://your-project.convex.cloud"
NEXT_PUBLIC_CONVEX_SITE_URL="https://your-project.convex.site"


